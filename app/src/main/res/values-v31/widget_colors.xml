<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- MD3 Widget Colors with Dynamic Color Support (Android 12+) -->
    
    <!-- Surface colors - використовуємо системні -->
    <color name="widget_surface">@android:color/system_neutral1_50</color>
    <color name="widget_on_surface">@android:color/system_neutral1_900</color>
    <color name="widget_surface_variant">@android:color/system_neutral2_100</color>
    <color name="widget_on_surface_variant">@android:color/system_neutral2_700</color>
    
    <!-- Primary colors - адаптуються до теми користувача -->
    <color name="widget_primary">@android:color/system_accent1_600</color>
    <color name="widget_on_primary">@android:color/system_accent1_0</color>
    <color name="widget_primary_container">@android:color/system_accent1_100</color>
    <color name="widget_on_primary_container">@android:color/system_accent1_900</color>
    
    <!-- Error colors - семантичні, але з Dynamic Colors -->
    <color name="widget_error">#BA1A1A</color>
    <color name="widget_on_error">#FFFFFF</color>
    <color name="widget_error_container">#FFDAD6</color>
    <color name="widget_on_error_container">#410002</color>
    
    <!-- Success colors - використовуємо accent3 (часто зелений) -->
    <color name="widget_success">@android:color/system_accent3_600</color>
    <color name="widget_on_success">@android:color/system_accent3_0</color>
    <color name="widget_success_container">@android:color/system_accent3_100</color>
    <color name="widget_on_success_container">@android:color/system_accent3_900</color>
    
    <!-- Warning colors - використовуємо accent2 (часто жовтий/помаранчевий) -->
    <color name="widget_warning">@android:color/system_accent2_600</color>
    <color name="widget_on_warning">@android:color/system_accent2_0</color>
    <color name="widget_warning_container">@android:color/system_accent2_100</color>
    <color name="widget_on_warning_container">@android:color/system_accent2_900</color>
    
    <!-- Outline -->
    <color name="widget_outline">@android:color/system_neutral1_500</color>
    <color name="widget_outline_variant">@android:color/system_neutral2_300</color>
    
    <!-- Legacy compatibility (DEPRECATED - використовуйте MD3 токени) -->
    <color name="widget_background_neutral">@color/widget_surface</color>
    <color name="widget_background_accent">@color/widget_primary_container</color>
    <color name="widget_text_primary">@color/widget_on_surface</color>
    <color name="widget_text_secondary">@color/widget_on_surface_variant</color>
    <color name="widget_status_positive">@color/widget_success_container</color>
    <color name="widget_status_negative">@color/widget_error_container</color>
    <color name="widget_status_warning">@color/widget_warning_container</color>
    <color name="widget_on_status">@color/widget_on_surface</color>
</resources>