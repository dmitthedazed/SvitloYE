<?xml version="1.0" encoding="utf-8"?>
<!-- 4x1 Wide Widget -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_status_dynamic"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="@null"
        android:tint="@color/widget_on_status" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="@color/widget_on_status"
            android:textSize="16sp"
            android:textStyle="bold" />
        
        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Until 14:00"
            android:textColor="@color/widget_on_status"
            android:alpha="0.8"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_remaining_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_pill_background"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="2h 15m"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>